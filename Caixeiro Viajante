def gerar_matriz_aleatoria(n, max_dist=100):
    matriz = [[0]*n for _ in range(n)]
    for i in range(n):
        for j in range(i+1, n):
            valor = random.randint(10, max_dist)
            matriz[i][j] = valor
            matriz[j][i] = valor
    return matriz


if __name__ == "__main__":
    # Lista de cidades
    cidades = ["A", "B", "C", "D", "E", "F"]

    # Gerar matriz de distâncias
    matriz = gerar_matriz_aleatoria(len(cidades))

    agente = TSPAgent(cidades, matriz)
    resultado = agente.resolver()

    print("\n=== RESULTADO ===")
    print("Caminho encontrado:")
    for i in resultado["caminho"]:
        print(cidades[i], end=" -> ")
    print(cidades[resultado["caminho"][0]])  # volta ao início

    print(f"\nCusto total: {resultado['custo']}")
    print(f"Estados visitados: {resultado['estados']}")
    print(f"Tempo de execução: {resultado['tempo']:.6f} segundos")

    print("\n=== MATRIZ DE DISTÂNCIAS ===")
    for linha in matriz:
        print(linha)
