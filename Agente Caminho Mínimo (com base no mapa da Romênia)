import heapq
import time

# Grafo (distâncias reais)
grafo = {
    "Arad": {"Zerind": 75, "Sibiu": 140, "Timisoara": 118},
    "Zerind": {"Arad": 75, "Oradea": 71},
    "Oradea": {"Zerind": 71, "Sibiu": 151},
    "Sibiu": {"Arad": 140, "Oradea": 151, "Fagaras": 99, "Rimnicu Vilcea": 80},
    "Timisoara": {"Arad": 118, "Lugoj": 111},
    "Lugoj": {"Timisoara": 111, "Mehadia": 70},
    "Mehadia": {"Lugoj": 70, "Drobeta": 75},
    "Drobeta": {"Mehadia": 75, "Craiova": 120},
    "Craiova": {"Drobeta": 120, "Rimnicu Vilcea": 146, "Pitesti": 138},
    "Rimnicu Vilcea": {"Sibiu": 80, "Craiova": 146, "Pitesti": 97},
    "Fagaras": {"Sibiu": 99, "Bucareste": 211},
    "Pitesti": {"Rimnicu Vilcea": 97, "Craiova": 138, "Bucareste": 101},
    "Bucareste": {"Fagaras": 211, "Pitesti": 101}
}

# Heurística (distância em linha reta até Bucareste)
heuristica = {
    "Arad": 366, "Zerind": 374, "Oradea": 380,
    "Sibiu": 253, "Timisoara": 329, "Lugoj": 244,
    "Mehadia": 241, "Drobeta": 242, "Craiova": 160,
    "Rimnicu Vilcea": 193, "Fagaras": 176,
    "Pitesti": 100, "Bucareste": 0
}


def a_estrela(inicio, objetivo):
    fila = []
    heapq.heappush(fila, (0, inicio))

    veio_de = {}
    custo = {inicio: 0}
    estados_visitados = 0

    while fila:
        _, atual = heapq.heappop(fila)
        estados_visitados += 1

        if atual == objetivo:
            break

        for vizinho, dist in grafo[atual].items():
            novo_custo = custo[atual] + dist

            if vizinho not in custo or novo_custo < custo[vizinho]:
                custo[vizinho] = novo_custo
                prioridade = novo_custo + heuristica[vizinho]
                heapq.heappush(fila, (prioridade, vizinho))
                veio_de[vizinho] = atual

    # reconstruir caminho
    caminho = []
    atual = objetivo
    while atual != inicio:
        caminho.append(atual)
        atual = veio_de[atual]
    caminho.append(inicio)
    caminho.reverse()

    return caminho, custo[objetivo], estados_visitados


def main():
    print("=== CAMINHO MÍNIMO - MAPA DA ROMÊNIA ===\n")

    inicio = input("Cidade inicial (ex: Arad): ")
    objetivo = "Bucareste"

    inicio_tempo = time.time()
    caminho, custo, visitados = a_estrela(inicio, objetivo)
    fim_tempo = time.time()

    print("\n=== RESULTADO ===")
    print("Caminho:", " -> ".join(caminho))
    print(f"Custo total: {custo}")
    print(f"Estados visitados: {visitados}")
    print(f"Tempo: {fim_tempo - inicio_tempo:.6f}s")


if __name__ == "__main__":
    main()
